# Токен вашего бота от @BotFather
BOT_TOKEN=ваш_токен_здесь

# Путь к словарям внутри контейнера (рекомендуется /data/dictionaries)
DICT_PATH=/data/dictionaries/

# Путь к файлу данных пользователей внутри контейнера
USER_DATA_FILE=/data/user_data.json

# Язык по умолчанию для новых пользователей (ru или en)
DEFAULT_LANG=ru

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ID администраторов через запятую (например: 12345678,87654321)
# Если пусто, команды добавления слов доступны всем
ADMIN_IDS=
