# Токен вашего бота от @BotFather
# Получить его можно у @BotFather в Telegram
BOT_TOKEN=ваш_токен_здесь

# Список ID администраторов через запятую (например: 12345678,87654321)
# Если оставить пустым, команды добавления слов (/addword, /dict_upload) будут доступны всем.
ADMIN_IDS=

# Язык по умолчанию для новых пользователей (ru или en)
DEFAULT_LANG=ru

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- Пути (Если запускаете через Docker, оставьте как есть) ---
# Путь к папке со словарями (для Docker уже настроено в docker-compose.yml)
# DICT_PATH=dictionaries/

# Файл с данными пользователей (для Docker уже настроено в docker-compose.yml)
# USER_DATA_FILE=user_data.json
